# DevPod workspace environment file — Agent Sandbox (Pi coding agent)
# Copy this file and rename -> workspace.env (repo root), then fill in your values.
# Use with:
#   devpod up . --workspace-env-file /path/to/workspace.env
#
# Note: Password can be plain text - it will be automatically obscured by rclone
# URL should be the base Nextcloud URL (WebDAV path is added automatically)

# Rclone configuration for Nextcloud sync
RCLONE_CONFIG_NEXTCLOUD_TYPE=webdav
RCLONE_CONFIG_NEXTCLOUD_URL=https://nx94317.your-storageshare.de
RCLONE_CONFIG_NEXTCLOUD_VENDOR=nextcloud
RCLONE_CONFIG_NEXTCLOUD_USER=<username>
RCLONE_CONFIG_NEXTCLOUD_PASS=<password>
RCLONE_CACHE_DIR=/tmp/rclone-cache

# Sync interval (seconds) — controls rclone sync loop
SYNC_LOOP_INTERVAL=60

# ─────────────────────────────────────────────────────────────────
# Sync paths (numbered pairs, must be consecutive starting from 1).
# MODE: "bisync" (bidirectional), "sync:local_to_remote" (one-way: local → remote),
#       or "sync:remote_to_local" (one-way: remote → local).
# IMPORTANT: Path numbers must be consecutive (1, 2, 3, ...) with no gaps.
# ─────────────────────────────────────────────────────────────────

# ═══════════════════════════════════════════════════════════════════
# BISYNC PATHS — developed/edited in-container, changes flow both ways
# ═══════════════════════════════════════════════════════════════════

# Path 1: Extensions (user-written *.ts, actively developed in-container)
SYNC_PATH_1_REMOTE=Devcontainers/pi-config/extensions/
SYNC_PATH_1_LOCAL=/root/.pi/agent/extensions
SYNC_PATH_1_MODE=bisync

# Path 2: Themes (user may edit .json locally)
SYNC_PATH_2_REMOTE=Devcontainers/pi-config/themes/
SYNC_PATH_2_LOCAL=/root/.pi/agent/themes
SYNC_PATH_2_MODE=bisync

# Path 3: Sessions (JSONL files — safe for bidirectional sync, no WAL/journal issues)
SYNC_PATH_3_REMOTE=Devcontainers/pi-sessions/agent-sandbox/
SYNC_PATH_3_LOCAL=/root/.pi/agent/sessions
SYNC_PATH_3_MODE=bisync

# ═══════════════════════════════════════════════════════════════════
# ONE-WAY PATHS — cloud is source of truth / backup target
# ═══════════════════════════════════════════════════════════════════

# Path 4: Config items (cloud → container only)
# Excludes bisynced subdirs (paths 1-3) + regenerated caches.
# Synced: settings.json, auth.json, AGENTS.md, SYSTEM.md, skills/**, prompts/**
SYNC_PATH_4_REMOTE=Devcontainers/pi-config/
SYNC_PATH_4_LOCAL=/root/.pi/agent
SYNC_PATH_4_MODE=sync:remote_to_local
SYNC_PATH_4_EXCLUDE=extensions/**,themes/**,sessions/**,npm/**,git/**,node_modules/**,package.json,package-lock.json,trust.json

# Path 5: Workspace backup (one-way: container → cloud)
# Protects against data loss if VM is destroyed before git push.
SYNC_PATH_5_REMOTE=Devcontainers/backups/workspaces/agent-sandbox
SYNC_PATH_5_LOCAL=/workspaces
SYNC_PATH_5_MODE=sync:local_to_remote
SYNC_PATH_5_EXCLUDE=.git/**,.devpod/**,node_modules/**,__pycache__/**,*.pyc,.venv/**,venv/**,dist/**,build/**,*.egg-info/**,.cache/**,.mypy_cache/**,.pytest_cache/**,.DS_Store,Thumbs.db,*.log,.env,*.swp,*.swo,*.sock,*~
