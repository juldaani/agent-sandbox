# AivoCode sidecar runtime configuration
# Copy this file and rename -> .aivocode.env (repo root), then fill in your values.

# Exa Search API key (required for websearch)
# Get one at https://dashboard.exa.ai/api-keys
EXA_API_KEY=your-key-here

# Language server configuration (TOML file with [[language]] entries).
# Defaults to /aivocode/.lsp_config.toml if not set.
# AIVOCODE_LSP_CONFIG_PATH=/workspaces/agent-sandbox/.aivocode_lsp.toml
