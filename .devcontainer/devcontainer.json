{
  "name": "agent-sandbox",
  "dockerComposeFile": ["docker-compose.yml"],
  "service": "sandbox",
  "workspaceFolder": "/workspaces/agent-sandbox",
  "shutdownAction": "none",
  "postCreateCommand": "mkdir -p ~/.ssh && ssh-keyscan github.com >> ~/.ssh/known_hosts 2>/dev/null && /usr/local/bin/sync-rclone.sh init",
  "postStartCommand": "supervisord -c /etc/supervisor/conf.d/supervisord.conf",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/opt/conda/envs/env-sandbox/bin/python"
      }
    }
  }
}
